## 7. Next.js Dynamic Sitemap (`app/sitemap.ts`)

If using App Router, replace the static XML with this:

```ts
import { MetadataRoute } from "next";

export default function sitemap(): MetadataRoute.Sitemap {
  return [
    {
      url: "https://gokulk.vercel.app",
      lastModified: new Date("2026-04-08"),
      changeFrequency: "monthly",
      priority: 1,
    },
    {
      url: "https://gokulk.vercel.app/projects/nextstop-bustracker",
      lastModified: new Date("2026-04-08"),
      changeFrequency: "monthly",
      priority: 0.8,
    },
    {
      url: "https://gokulk.vercel.app/projects/ai-resume-analyzer",
      lastModified: new Date("2026-04-08"),
      changeFrequency: "monthly",
      priority: 0.8,
    },
    {
      url: "https://gokulk.vercel.app/projects/securepower",
      lastModified: new Date("2026-04-08"),
      changeFrequency: "monthly",
      priority: 0.8,
    },
  ];
}
```

