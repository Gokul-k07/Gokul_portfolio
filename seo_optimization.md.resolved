    "React developer India",
    "Next.js developer",
    "full stack developer portfolio",
  ],
  authors: [{ name: "Gokul K", url: "https://gokulk.vercel.app" }],
  creator: "Gokul K",
  publisher: "Gokul K",
  alternates: {
    canonical: "https://gokulk.vercel.app",
  },
  openGraph: {
    type: "website",
    url: "https://gokulk.vercel.app",
    title: "Gokul K — Full Stack Developer & AI Engineer",
    description:
      "Gokul K builds production-ready web apps, backend systems, and AI-powered experiences. Based in Tamil Nadu, India.",
    siteName: "Gokul K Portfolio",
